<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <title>{{ subject }}</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
      background: linear-gradient(180deg, #f7f9fc 0%, #eef3f8 100%);
      color: #1f2937;
    }
    .container {
      max-width: 760px;
      margin: 32px auto;
      padding: 32px;
      background: rgba(255, 255, 255, 0.96);
      border-radius: 20px;
      box-shadow: 0 18px 48px rgba(15, 23, 42, 0.08);
    }
    .content h1, .content h2, .content h3 {
      color: #0f172a;
    }
    .content a {
      color: #0f766e;
    }
    .footer {
      margin-top: 32px;
      padding-top: 16px;
      border-top: 1px solid #dbe4ee;
      color: #64748b;
      font-size: 12px;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="content">
      {{ html_content | safe }}
    </div>
    <div class="footer">
      Generated by Personal Digest Agent.
    </div>
  </div>
</body>
</html>

